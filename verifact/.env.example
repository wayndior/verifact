# ─────────────────────────────────────────────────────────────────
#  Verifact — Environment Variables
#  Copy to .env for local dev, set each value in Vercel dashboard
#  for production. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# ── Database (Turso) ──────────────────────────────────────────────
# Get from: https://turso.tech → your database → Connect
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── App URLs ──────────────────────────────────────────────────────
BASE_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# ── File Storage ──────────────────────────────────────────────────
# Not needed on Vercel (files processed in memory).
# Only required when running locally or on a VPS.
# UPLOADS_PATH=/var/www/verifact/uploads

# ── Error Tracking (optional) ─────────────────────────────────────
# SENTRY_BACKEND_DSN=https://xxxxx@sentry.io/yyyyy
